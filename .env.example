# ==============================
# Environment Variables
# ==============================

# ---- SERVER ----
# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/niyukti?schema=public"

# App
NODE_ENV="development"
PORT=3001
CLIENT_URL="http://localhost:3000"

# JWT
JWT_SECRET="your-strong-jwt-secret-min-32-chars"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-strong-refresh-secret-min-32-chars"
JWT_REFRESH_EXPIRES_IN="30d"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@niyukti.com"

# ---- CLIENT ----
# Local development only. Leave this unset on Vercel when you want the app to
# use the same-origin /api path instead.
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# Optional Vercel/Next.js rewrite target. Set this in the Vercel project envs
# to your deployed backend API URL, including the /api suffix.
API_URL="https://your-backend-domain/api"
