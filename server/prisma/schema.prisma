// Niyukti — Temporary Event Staffing Platform
// Prisma Schema — Production Ready

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================================================
// ENUMS
// ==================================================

enum Role {
  ADMIN
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUOTATION_SENT
  CONFIRMED
  LOST
}

enum BookingStatus {
  DRAFT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum StaffStatus {
  ACTIVE
  INACTIVE
  AVAILABLE
  ASSIGNED
  BLACKLISTED
}

enum AssignmentStatus {
  ASSIGNED
  ACCEPTED
  REJECTED
  COMPLETED
  NO_SHOW
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  LATE
  NO_SHOW
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  OVERDUE
}

enum InvoiceStatus {
  NOT_GENERATED
  GENERATED
  SENT
}

enum StaffPayoutStatus {
  PENDING
  PAID
}

// ==================================================
// USERS
// ==================================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  inquiriesHandled   Inquiry[]              @relation("InquiryHandler")
  inquiriesCreated   Inquiry[]              @relation("InquiryCreator")
  clientsCreated     Client[]
  staffCreated       Staff[]
  eventsCreated      Event[]                @relation("EventCreator")
  eventsSupervisored Event[]                @relation("EventSupervisor")
  assignmentsCreated EventStaffAssignment[]
  quotationsCreated  Quotation[]
  paymentsCreated    Payment[]
  attendanceMarked   Attendance[]

  @@map("users")
}

// ==================================================
// INQUIRIES
// ==================================================

model Inquiry {
  id          String        @id @default(cuid())
  fullName    String
  companyName String?
  phone       String
  email       String
  eventType   String
  eventDate   DateTime
  location    String
  staffCount  Int
  staffRoles  String[]
  message     String?
  status      InquiryStatus @default(NEW)

  // Relations
  handledById String?
  handledBy   User?   @relation("InquiryHandler", fields: [handledById], references: [id])
  createdById String?
  createdBy   User?   @relation("InquiryCreator", fields: [createdById], references: [id])

  clientId  String?
  client    Client? @relation(fields: [clientId], references: [id])

  quotations Quotation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([createdAt])
  @@map("inquiries")
}

// ==================================================
// CLIENTS
// ==================================================

model Client {
  id          String   @id @default(cuid())
  name        String
  companyName String?
  phone       String
  email       String   @unique
  address     String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  inquiries  Inquiry[]
  events     Event[]
  quotations Quotation[]
  payments   Payment[]

  @@index([email])
  @@index([isActive])
  @@map("clients")
}

// ==================================================
// STAFF
// ==================================================

model Staff {
  id                 String      @id @default(cuid())
  fullName           String
  phone              String
  email              String      @unique
  city               String
  role               String      // e.g. Host, Promoter, Security
  skills             String[]
  experienceYears    Int         @default(0)
  availability       Boolean     @default(true)
  isVerified         Boolean     @default(false)
  rating             Float?
  notes              String?
  status             StaffStatus @default(ACTIVE)
  isDeleted          Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  documents   StaffDocument[]
  assignments EventStaffAssignment[]
  attendance  Attendance[]

  @@index([status])
  @@index([isDeleted])
  @@index([city])
  @@index([role])
  @@map("staff")
}

model StaffDocument {
  id            String   @id @default(cuid())
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type          String   // e.g. ID_PROOF, PHOTO, CERTIFICATE
  url           String
  cloudinaryId  String
  uploadedAt    DateTime @default(now())

  @@index([staffId])
  @@map("staff_documents")
}

// ==================================================
// EVENTS
// ==================================================

model Event {
  id           String        @id @default(cuid())
  name         String
  type         String
  date         DateTime
  startTime    String
  endTime      String
  location     String
  staffCount   Int
  staffRoles   String[]
  notes        String?
  status       BookingStatus @default(DRAFT)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  supervisorId String?
  supervisor   User?   @relation("EventSupervisor", fields: [supervisorId], references: [id])

  createdById String?
  createdBy   User?   @relation("EventCreator", fields: [createdById], references: [id])

  assignments EventStaffAssignment[]
  quotations  Quotation[]
  attendance  Attendance[]
  payments    Payment[]

  @@index([status])
  @@index([date])
  @@index([clientId])
  @@map("events")
}

// ==================================================
// EVENT STAFF ASSIGNMENTS
// ==================================================

model EventStaffAssignment {
  id        String           @id @default(cuid())
  role      String
  status    AssignmentStatus @default(ASSIGNED)
  notes     String?
  assignedAt DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  attendance Attendance[]

  @@unique([eventId, staffId])
  @@index([status])
  @@map("event_staff_assignments")
}

// ==================================================
// QUOTATIONS
// ==================================================

model Quotation {
  id            String          @id @default(cuid())
  title         String
  subtotal      Float           @default(0)
  serviceCharge Float           @default(0)
  tax           Float           @default(0)
  discount      Float           @default(0)
  total         Float           @default(0)
  status        QuotationStatus @default(DRAFT)
  sentAt        DateTime?
  notes         String?
  isDeleted     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  inquiryId String?
  inquiry   Inquiry? @relation(fields: [inquiryId], references: [id])

  eventId String?
  event   Event?  @relation(fields: [eventId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  items QuotationItem[]

  @@index([status])
  @@index([isDeleted])
  @@map("quotations")
}

model QuotationItem {
  id            String    @id @default(cuid())
  role          String
  quantity      Int
  ratePerPerson Float
  days          Int       @default(1)
  total         Float

  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
  @@map("quotation_items")
}

// ==================================================
// ATTENDANCE
// ==================================================

model Attendance {
  id       String           @id @default(cuid())
  checkIn  DateTime?
  checkOut DateTime?
  status   AttendanceStatus @default(PRESENT)
  remarks  String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  assignmentId String
  assignment   EventStaffAssignment @relation(fields: [assignmentId], references: [id])

  staffId String
  staff   Staff  @relation(fields: [staffId], references: [id])

  markedById String?
  markedBy   User?   @relation(fields: [markedById], references: [id])

  @@unique([eventId, staffId])
  @@index([status])
  @@map("attendance")
}

// ==================================================
// PAYMENTS
// ==================================================

model Payment {
  id                String            @id @default(cuid())
  totalAmount       Float
  advancePaid       Float             @default(0)
  balanceAmount     Float
  status            PaymentStatus     @default(PENDING)
  invoiceStatus     InvoiceStatus     @default(NOT_GENERATED)
  staffPayoutStatus StaffPayoutStatus @default(PENDING)
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  @@unique([eventId])
  @@index([status])
  @@map("payments")
}

